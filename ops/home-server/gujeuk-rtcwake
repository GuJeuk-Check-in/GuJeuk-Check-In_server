#!/usr/bin/env bash
set -euo pipefail

MAX_SECONDS=$((7 * 24 * 60 * 60))

if [ "$EUID" -ne 0 ]; then
  echo 'This command must run as root.' >&2
  exit 1
fi

validate_seconds() {
  local seconds="${1:-}"

  if ! [[ "$seconds" =~ ^[0-9]+$ ]]; then
    echo 'Invalid number of seconds.' >&2
    exit 1
  fi

  if [ "$seconds" -lt 60 ] || [ "$seconds" -gt "$MAX_SECONDS" ]; then
    echo 'Seconds must be between 60 and 604800.' >&2
    exit 1
  fi
}

case "${1:-}" in
  schedule)
    validate_seconds "${2:-}"
    exec /usr/sbin/rtcwake -m off -s "$2"
    ;;
  check)
    validate_seconds "${2:-}"
    /usr/sbin/rtcwake -n -m off -s "$2"
    printf '0\n' >/sys/class/rtc/rtc0/wakealarm
    ;;
  show)
    exec /usr/sbin/rtcwake -m show
    ;;
  *)
    echo 'Allowed actions: schedule <seconds>, check <seconds>, show' >&2
    exit 1
    ;;
esac
